---
---

<!-- Floating Chat Bubble -->
<div id="chat-container" class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-4">

  <!-- Chat Window -->
  <div id="chat-window" class="hidden w-80 md:w-96 rounded-2xl overflow-hidden shadow-2xl"
       style="background-color: #1e293b; border: 1px solid #334155;">

    <!-- Header -->
    <div class="px-4 py-3 flex items-center justify-between"
         style="background-color: #0f172a; border-bottom: 1px solid #334155;">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold"
             style="background: linear-gradient(135deg, #6366f1, #22c55e);">
          YM
        </div>
        <div>
          <p class="text-sm font-semibold" style="color: var(--color-foreground);">Ask About Yokeswaran</p>
          <p class="text-xs" style="color: #22c55e;">● Online</p>
        </div>
      </div>
      <button id="close-chat" class="text-slate-400 hover:text-white transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Messages -->
    <div id="chat-messages" class="h-80 overflow-y-auto p-4 space-y-4 flex flex-col">

      <!-- Welcome Message -->
      <div class="flex gap-2">
        <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold shrink-0 mt-1"
             style="background: linear-gradient(135deg, #6366f1, #22c55e);">
          YM
        </div>
        <div class="rounded-2xl rounded-tl-none px-4 py-3 text-sm max-w-xs"
             style="background-color: #334155; color: #e2e8f0;">
          Hi! 👋 I'm Yokeswaran's AI assistant. Ask me anything about his skills, projects, or experience!
        </div>
      </div>

      <!-- Suggested Questions -->
      <div class="flex flex-wrap gap-2 ml-9">
        {[
          "What are your skills?",
          "Tell me about your projects",
          "What is AEP?",
          "How to contact you?"
        ].map(q => (
          <button 
            class="suggested-q text-xs px-3 py-1 rounded-full transition-all"
            style="background-color: #0f172a; color: #94a3b8; border: 1px solid #334155;"
          >
            {q}
          </button>
        ))}
      </div>

    </div>

    <!-- Input -->
    <div class="px-4 py-3" style="border-top: 1px solid #334155;">
      <div class="flex gap-2">
        <input 
          id="chat-input"
          type="text"
          placeholder="Ask me anything..."
          class="flex-1 px-4 py-2 rounded-xl text-sm outline-none"
          style="background-color: #0f172a; border: 1px solid #334155; color: #e2e8f0;"
        />
        <button 
          id="send-message"
          class="w-9 h-9 rounded-xl flex items-center justify-center transition-all"
          style="background-color: var(--color-primary);"
        >
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
        </button>
      </div>
    </div>

  </div>

  <!-- Bubble Button -->
  <button 
    id="chat-bubble"
    class="w-14 h-14 rounded-full flex items-center justify-center shadow-lg transition-all duration-300 hover:scale-110"
    style="background: linear-gradient(135deg, #6366f1, #22c55e);"
  >
    <svg id="bubble-icon" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
            d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
  </button>

</div>

<script>
const GROQ_API_KEY = import.meta.env.PUBLIC_GROQ_API_KEY;

const SYSTEM_PROMPT = "You are an AI assistant for Yokeswaran MP's portfolio website. Answer questions about Yokeswaran in a friendly, professional and concise way. Keep answers to 2-3 sentences. Here is what you know: NAME: Yokeswaran MP. ROLE: Data Engineer and Adobe AEP Architect based in India. EMAIL: yokeswaranmp@gmail.com. GITHUB: github.com/yokeswaranmp. LINKEDIN: linkedin.com/in/yokeswaranmp. SKILLS: Apache Spark, Kafka, dbt, Airflow, Python, SQL, Adobe AEP Real-Time CDP, Journey Optimizer, XDM Schema Design, AWS, Azure, Docker, n8n, Make.com, OpenAI API. PROJECTS: Real-Time Customer Data Pipeline processing 10M+ events daily using Kafka and Spark. Adobe AEP RTCDP Implementation for retail client. Automated Blog Publishing Pipeline using Make.com and GitHub. AI Blog Draft Generator. ACHIEVEMENTS: Adobe Certified Expert in AEP. AWS Certified Data Analytics Specialty. BLOG TOPICS: Adobe AEP, RTDM, Data Engineering, Automation, AI Experiments. AVAILABILITY: Open to new opportunities. Contact via email or LinkedIn.";

const bubble     = document.getElementById('chat-bubble');
const chatWindow = document.getElementById('chat-window');
const closeBtn   = document.getElementById('close-chat');
const input      = document.getElementById('chat-input');
const sendBtn    = document.getElementById('send-message');
const messages   = document.getElementById('chat-messages');
const suggestedQs = document.querySelectorAll('.suggested-q');

bubble?.addEventListener('click', () => {
  chatWindow?.classList.toggle('hidden');
  input?.focus();
});

closeBtn?.addEventListener('click', () => {
  chatWindow?.classList.add('hidden');
});

suggestedQs.forEach(btn => {
  btn.addEventListener('click', () => {
    const question = btn.textContent?.trim();
    if (question) sendMessage(question);
  });
});

input?.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') sendMessage(input.value);
});

sendBtn?.addEventListener('click', () => {
  sendMessage(input.value);
});

function addMessage(text, isUser) {
  const div = document.createElement('div');
  div.className = isUser ? 'flex gap-2 justify-end' : 'flex gap-2';

  if (!isUser) {
    div.innerHTML = '<div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#22c55e);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:bold;color:white;flex-shrink:0;margin-top:4px;">YM</div><div style="background-color:#334155;color:#e2e8f0;padding:10px 14px;border-radius:16px;border-top-left-radius:4px;font-size:13px;max-width:240px;line-height:1.5;">' + text + '</div>';
  } else {
    div.innerHTML = '<div style="background-color:#6366f1;color:white;padding:10px 14px;border-radius:16px;border-top-right-radius:4px;font-size:13px;max-width:240px;line-height:1.5;">' + text + '</div>';
  }

  messages?.appendChild(div);
  messages?.scrollTo({ top: messages.scrollHeight, behavior: 'smooth' });
}

function addTyping() {
  const div = document.createElement('div');
  div.id = 'typing-indicator';
  div.className = 'flex gap-2';
  div.innerHTML = '<div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#22c55e);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:bold;color:white;flex-shrink:0;">YM</div><div style="background-color:#334155;color:#94a3b8;padding:10px 14px;border-radius:16px;border-top-left-radius:4px;font-size:13px;">Thinking...</div>';
  messages?.appendChild(div);
  messages?.scrollTo({ top: messages.scrollHeight, behavior: 'smooth' });
}

function removeTyping() {
  document.getElementById('typing-indicator')?.remove();
}

async function sendMessage(text) {
  if (!text?.trim()) return;
  if (input) input.value = '';

  addMessage(text, true);
  addTyping();

  try {
    const payload = {
      model: "llama-3.3-70b-versatile",
      messages: [
        { role: "system", content: SYSTEM_PROMPT },
        { role: "user", content: text }
      ],
      max_tokens: 200,
      temperature: 0.7
    };

    console.log("Sending to Groq:", JSON.stringify(payload));

    const response = await fetch("https://api.groq.com/openai/v1/chat/completions", {
      method: "POST",
      headers: {
        "Authorization": "Bearer " + GROQ_API_KEY,
        "Content-Type": "application/json"
      },
      body: JSON.stringify(payload)
    });

    const data = await response.json();
    console.log("Groq response:", data);
    removeTyping();

    if (!response.ok) {
      console.error("Groq error:", data);
      addMessage("Sorry I could not get a response. Please try again!", false);
      return;
    }

    const reply = data.choices?.[0]?.message?.content || "Sorry I could not get a response!";
    addMessage(reply, false);

  } catch (error) {
    console.error("Fetch error:", error);
    removeTyping();
    addMessage("Sorry something went wrong. Please try again!", false);
  }
}
</script>