---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = [
  'All',
  'Adobe AEP',
  'RTDM',
  'Data Engineering',
  'Automation',
  'AI Experiments'
];
---

<BaseLayout 
  title="Blog" 
  description="Weekly articles on Data Engineering, Adobe AEP, Automation and AI Experiments"
>
  <section class="max-w-5xl mx-auto px-6 py-24">

    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold mb-4" 
          style="color: var(--color-foreground);">
        Blog
      </h1>
      <p class="text-lg" style="color: #94a3b8;">
        Weekly writings on Data Engineering, Adobe AEP, Automation and AI Experiments.
      </p>
    </div>

    <!-- Category Filter -->
    <div class="flex flex-wrap gap-3 mb-12" id="category-filters">
      {categories.map(cat => (
        <button
          class="category-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 cursor-pointer"
          data-category={cat}
          style={cat === 'All' 
            ? 'background-color: var(--color-primary); color: white;' 
            : 'background-color: #1e293b; color: #94a3b8; border: 1px solid #334155;'}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Post Count -->
    <p class="text-sm mb-8" style="color: #64748b;">
      <span id="post-count">{sortedPosts.length}</span> articles
    </p>

    <!-- Blog Posts Grid -->
    <div class="grid gap-6" id="posts-grid">
      {sortedPosts.map(post => (
        <article
          class="card group cursor-pointer"
          data-category={post.data.category}
        >
          <a href={`/blog/${post.id}`} class="block space-y-4">

            <!-- Top Row -->
            <div class="flex items-start justify-between gap-4">
              <span class="px-3 py-1 rounded-full text-xs font-medium border shrink-0"
                    style="border-color: var(--color-primary); color: var(--color-primary);">
                {post.data.category}
              </span>
              <span class="text-xs shrink-0" style="color: #64748b;">
                {new Date(post.data.date).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric'
                })}
              </span>
            </div>

            <!-- Title -->
            <h2 class="text-xl font-bold group-hover:text-primary transition-colors duration-200"
                style="color: var(--color-foreground);">
              {post.data.title}
            </h2>

            <!-- Description -->
            <p class="text-sm leading-relaxed line-clamp-2" style="color: #94a3b8;">
              {post.data.description}
            </p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag: string) => (
                <span class="px-2 py-0.5 rounded text-xs"
                      style="background-color: #0f172a; color: #64748b; border: 1px solid #1e293b;">
                  #{tag}
                </span>
              ))}
            </div>

            <!-- Read More -->
            <div class="flex items-center gap-2 text-sm font-medium"
                 style="color: var(--color-primary);">
              Read article 
              <span class="group-hover:translate-x-1 transition-transform duration-200">→</span>
            </div>

          </a>
        </article>
      ))}
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden text-center py-16">
      <p class="text-lg" style="color: #64748b;">No posts in this category yet.</p>
      <p class="text-sm mt-2" style="color: #475569;">Check back soon!</p>
    </div>

  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.category-btn');
  const posts = document.querySelectorAll('#posts-grid article');
  const postCount = document.getElementById('post-count');
  const emptyState = document.getElementById('empty-state');
  const postsGrid = document.getElementById('posts-grid');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const selected = btn.getAttribute('data-category');

      // Update button styles
      buttons.forEach(b => {
        b.setAttribute('style', 
          'background-color: #1e293b; color: #94a3b8; border: 1px solid #334155;'
        );
      });
      btn.setAttribute('style', 
        'background-color: var(--color-primary); color: white;'
      );

      // Filter posts
      let visible = 0;
      posts.forEach(post => {
        const cat = post.getAttribute('data-category');
        const show = selected === 'All' || cat === selected;
        (post as HTMLElement).style.display = show ? 'block' : 'none';
        if (show) visible++;
      });

      // Update count
      if (postCount) postCount.textContent = String(visible);

      // Show/hide empty state
      if (visible === 0) {
        emptyState?.classList.remove('hidden');
        postsGrid?.classList.add('hidden');
      } else {
        emptyState?.classList.add('hidden');
        postsGrid?.classList.remove('hidden');
      }
    });
  });
</script>